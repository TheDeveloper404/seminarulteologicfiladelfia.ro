# Maileroo — formular de contact (server-side, Server Action)
# Vezi https://maileroo.com/ — API Key din dashboard, domeniu seminarulteologicfiladelfia.ro verificat (SPF/DKIM)
MAILEROO_API_KEY=

# Portal admin/student — Postgres pe VPS (vezi docs/decizie-infrastructura-si-functionalitati-noi.md)
DATABASE_URL=postgresql://user:parola@host:5432/seminar

# Cloudflare Turnstile — anti-bot pe login admin/student (vezi docs/audit-securitate.md)
# Dashboard Cloudflare → Turnstile → Add site → widget mod "Managed" (invizibil pt. majoritatea
# utilizatorilor). Fără ele, login-ul funcționează normal, doar fără protecția anti-bot.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
